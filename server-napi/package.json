{
  "name": "protein-design-backend",
  "version": "1.0.0",
  "description": "Backend server for Protein Design Studio",
  "main": "dist/server.js",
  "scripts": {
    "build": "esbuild server.ts --bundle --platform=node --outfile=dist/bundle.cjs --format=cjs",
    "start": "node dist/bundle.cjs",
    "dev": "npm run build"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.5"
  }
}
